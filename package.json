{
  "name": "@grahlnn/comps",
  "version": "0.2.1",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "typescript": "^5"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "description": "React components from grahlnn/comps.",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "bun run ./scripts/clean-dist.ts",
    "build": "bun run clean && bun run build:js && bun run build:types",
    "build:js": "bun build ./index.ts --outdir ./dist --format esm --target browser --external react --external react/jsx-runtime --external @chenglou/pretext",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@chenglou/pretext": "0.0.6"
  }
}
